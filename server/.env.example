PORT=5001
JWT_SECRET=change-this-secret

# Seed test data on startup (22 regulars + 6 subs)
SEED_TEST_DATA=true

# Email notifications via Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourleague@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=yourleague@gmail.com

# SMS provider selection: twilio or voipms
SMS_PROVIDER=voipms

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# voip.ms SMS
VOIPMS_API_USERNAME=
VOIPMS_API_PASSWORD=
VOIPMS_FROM_NUMBER=